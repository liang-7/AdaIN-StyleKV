\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces $\gamma $强度系数敏感性分析结果（5块配置，固定AdaIN + ControlNet）。$\gamma =0$时主要保留内容特征，风格注入较弱；$\gamma =1$时风格化程度最高，但内容改变也更明显。}}{6}{table.caption.13}\protected@file@percent }
\newlabel{tab:gamma_ablation}{{6}{6}{$\gamma $强度系数敏感性分析结果（5块配置，固定AdaIN + ControlNet）。$\gamma =0$时主要保留内容特征，风格注入较弱；$\gamma =1$时风格化程度最高，但内容改变也更明显。}{table.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces $\gamma $取值对FID、Art-FID和LPIPS的影响。随着$\gamma $增大，风格保真度提升但内容变化也增加，$\gamma =0.6$取得较好的综合平衡。}}{6}{figure.caption.14}\protected@file@percent }
\newlabel{fig:comprehensive}{{10}{6}{$\gamma $取值对FID、Art-FID和LPIPS的影响。随着$\gamma $增大，风格保真度提升但内容变化也增加，$\gamma =0.6$取得较好的综合平衡。}{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces 5块配置（本文方法）下不同$\gamma $值的风格迁移效果。从左至右$\gamma =0.2,0.4,0.8,1.0$，可清晰观察风格纹理随$\gamma $增大而逐步增强的渐变过程。}}{6}{figure.caption.15}\protected@file@percent }
\newlabel{fig:gamma_5blk}{{11}{6}{5块配置（本文方法）下不同$\gamma $值的风格迁移效果。从左至右$\gamma =0.2,0.4,0.8,1.0$，可清晰观察风格纹理随$\gamma $增大而逐步增强的渐变过程。}{figure.caption.15}{}}
