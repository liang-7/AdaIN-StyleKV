\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces 7组变体在5000张生成图像上的定量评估结果。FID衡量与内容域的分布距离（越低表示整体特征分布越接近原始内容）；Art-FID衡量与风格域的分布距离（越低表示风格相似度越高）；LPIPS衡量感知改变程度（风格化必然引入感知变化，适中的LPIPS值表示在内容可辨识前提下的有效风格迁移）。粗体为完整方法（V7）的结果。}}{5}{table.caption.8}\protected@file@percent }
\newlabel{tab:quant_results}{{5}{5}{7组变体在5000张生成图像上的定量评估结果。FID衡量与内容域的分布距离（越低表示整体特征分布越接近原始内容）；Art-FID衡量与风格域的分布距离（越低表示风格相似度越高）；LPIPS衡量感知改变程度（风格化必然引入感知变化，适中的LPIPS值表示在内容可辨识前提下的有效风格迁移）。粗体为完整方法（V7）的结果。}{table.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces 7组方法变体在FID、Art-FID和LPIPS三项指标上的定量对比，三项指标均为越低越好。FID反映生成结果与内容域的分布距离，Art-FID反映与目标艺术风格域的接近程度，LPIPS反映感知层面的图像变化幅度。V6（Ours w/o AdaIN）取得最低Art-FID，风格注入更强；完整方法V7（Ours AdaIN, $\gamma =0.6$）获得更低LPIPS，感知变化更温和。}}{5}{figure.caption.9}\protected@file@percent }
\newlabel{fig:variants2}{{6}{5}{7组方法变体在FID、Art-FID和LPIPS三项指标上的定量对比，三项指标均为越低越好。FID反映生成结果与内容域的分布距离，Art-FID反映与目标艺术风格域的接近程度，LPIPS反映感知层面的图像变化幅度。V6（Ours w/o AdaIN）取得最低Art-FID，风格注入更强；完整方法V7（Ours AdaIN, $\gamma =0.6$）获得更低LPIPS，感知变化更温和。}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces 7组方法变体在FID、Art-FID和LPIPS三项指标上的排名热力图，排名越低表示表现越好。}}{6}{figure.caption.10}\protected@file@percent }
\newlabel{fig:rank_heatmap}{{7}{6}{7组方法变体在FID、Art-FID和LPIPS三项指标上的排名热力图，排名越低表示表现越好。}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces 7组方法变体的风格迁移可视化对比。V6呈现更强的风格纹理迁移，V7在加入AdaIN后色彩与感知变化更稳定。}}{6}{figure.caption.11}\protected@file@percent }
\newlabel{fig:variants1}{{8}{6}{7组方法变体的风格迁移可视化对比。V6呈现更强的风格纹理迁移，V7在加入AdaIN后色彩与感知变化更稳定。}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces 不同块数配置与AdaIN使用与否的风格迁移效果对比。更多块数（5块 vs 1块）带来更强的风格注入，但也引入更多内容结构变化；AdaIN模块有助于在风格注入的同时保持色彩和谐。}}{6}{figure.caption.12}\protected@file@percent }
\newlabel{fig:block_adain}{{9}{6}{不同块数配置与AdaIN使用与否的风格迁移效果对比。更多块数（5块 vs 1块）带来更强的风格注入，但也引入更多内容结构变化；AdaIN模块有助于在风格注入的同时保持色彩和谐。}{figure.caption.12}{}}
