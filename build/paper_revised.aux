\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces $\gamma $消融实验结果（5块配置，固定AdaIN + ControlNet）。$\gamma =0$时完全保留内容特征，风格最弱；$\gamma =1$时完全使用风格特征，内容改变最大。$\gamma =0.6$为最佳权衡点——风格强度足够且内容结构保持良好。}}{7}{table.caption.9}\protected@file@percent }
\newlabel{tab:gamma_ablation}{{6}{7}{$\gamma $消融实验结果（5块配置，固定AdaIN + ControlNet）。$\gamma =0$时完全保留内容特征，风格最弱；$\gamma =1$时完全使用风格特征，内容改变最大。$\gamma =0.6$为最佳权衡点——风格强度足够且内容结构保持良好。}{table.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces 块数消融实验结果（固定$\gamma =0.6$，使用AdaIN）。1块配置风格注入最保守，5块配置获得最优Art-FID，2块配置结果居中。更多块带来更强风格注入，5块在效果与效率之间取得最佳平衡。}}{7}{table.caption.10}\protected@file@percent }
\newlabel{tab:block_ablation}{{7}{7}{块数消融实验结果（固定$\gamma =0.6$，使用AdaIN）。1块配置风格注入最保守，5块配置获得最优Art-FID，2块配置结果居中。更多块带来更强风格注入，5块在效果与效率之间取得最佳平衡。}{table.caption.10}{}}
