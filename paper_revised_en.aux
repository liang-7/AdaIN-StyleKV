\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Stylization results of AdaIN StyleKV. Horizontally, $\gamma $ increases from 0.2 to 1.0; vertically, 1-proc, 5-proc, and 10-proc configurations are shown with and without AdaIN. The 5-proc + AdaIN configuration (our full method) gives a useful balance between style intensity and content fidelity near $\gamma =0.6$.}}{1}{figure.1}\protected@file@percent }
\newlabel{fig:gallery}{{1}{1}{Stylization results of AdaIN StyleKV. Horizontally, $\gamma $ increases from 0.2 to 1.0; vertically, 1-proc, 5-proc, and 10-proc configurations are shown with and without AdaIN. The 5-proc + AdaIN configuration (our full method) gives a useful balance between style intensity and content fidelity near $\gamma =0.6$}{figure.1}{}}
