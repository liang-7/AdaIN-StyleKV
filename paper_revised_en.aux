\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces U-Net architecture in Stable Diffusion, showing the encoder, middle block, and decoder with their ResNet and self-attention layers. We confine KV fusion to the target block \texttt  {up\_blocks.0.attentions.1} (red), leaving all other attention processors untouched.}}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:unet_arch}{{3}{4}{U-Net architecture in Stable Diffusion, showing the encoder, middle block, and decoder with their ResNet and self-attention layers. We confine KV fusion to the target block \texttt {up\_blocks.0.attentions.1} (red), leaving all other attention processors untouched}{figure.caption.3}{}}
