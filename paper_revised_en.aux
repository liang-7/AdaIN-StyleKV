\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Design of 7 method variants. CtrlN = ControlNet; Scope = target blocks (blk) or processors (p); KV = KV fusion enabled.}}{5}{table.caption.8}\protected@file@percent }
\newlabel{tab:variants}{{5}{5}{Design of 7 method variants. CtrlN = ControlNet; Scope = target blocks (blk) or processors (p); KV = KV fusion enabled}{table.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Quantitative comparison of 7 method variants across FID, Art-FID, and LPIPS metrics (lower is better for all three). FID reflects distribution distance from the content domain, Art-FID reflects proximity to the target artistic style domain, and LPIPS reflects the perceptual-level image change magnitude. V6 (Ours w/o AdaIN) achieves the lowest Art-FID, indicating stronger style injection; compared with V6, the full method V7 (Ours AdaIN, $\gamma =0.6$) reduces LPIPS, indicating milder perceptual change.}}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:variants2}{{6}{5}{Quantitative comparison of 7 method variants across FID, Art-FID, and LPIPS metrics (lower is better for all three). FID reflects distribution distance from the content domain, Art-FID reflects proximity to the target artistic style domain, and LPIPS reflects the perceptual-level image change magnitude. V6 (Ours w/o AdaIN) achieves the lowest Art-FID, indicating stronger style injection; compared with V6, the full method V7 (Ours AdaIN, $\gamma =0.6$) reduces LPIPS, indicating milder perceptual change}{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Horizontal comparison of outputs from different method configurations on the ``man'' content image. The upper labels indicate the corresponding method configuration and allow comparison of style injection intensity and content preservation.}}{6}{figure.caption.9}\protected@file@percent }
\newlabel{fig:variant_progress}{{4}{6}{Horizontal comparison of outputs from different method configurations on the ``man'' content image. The upper labels indicate the corresponding method configuration and allow comparison of style injection intensity and content preservation}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Method variant comparison on two different content-style pairings.}}{6}{figure.caption.10}\protected@file@percent }
\newlabel{fig:variant_compare}{{5}{6}{Method variant comparison on two different content-style pairings}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Quantitative Results}{6}{subsection.4.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Quantitative evaluation results of 7 variants on 5000 generated images. FID measures distribution distance from the content domain (lower indicates closer overall feature distribution to original content); Art-FID measures distribution distance from the style domain (lower indicates higher style similarity); LPIPS measures the degree of perceptual change (stylization inevitably introduces perceptual changes; moderate LPIPS values indicate effective style transfer while content remains recognizable). Bold indicates the full method (V7).}}{6}{table.caption.11}\protected@file@percent }
\newlabel{tab:quant_results}{{6}{6}{Quantitative evaluation results of 7 variants on 5000 generated images. FID measures distribution distance from the content domain (lower indicates closer overall feature distribution to original content); Art-FID measures distribution distance from the style domain (lower indicates higher style similarity); LPIPS measures the degree of perceptual change (stylization inevitably introduces perceptual changes; moderate LPIPS values indicate effective style transfer while content remains recognizable). Bold indicates the full method (V7)}{table.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Ranking heatmap of the 7 method variants across FID, Art-FID, and LPIPS metrics (lower rank indicates better performance).}}{6}{figure.caption.12}\protected@file@percent }
\newlabel{fig:rank_heatmap}{{7}{6}{Ranking heatmap of the 7 method variants across FID, Art-FID, and LPIPS metrics (lower rank indicates better performance)}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Content-style trade-off comparison of method variants on FID and Art-FID.}}{6}{figure.caption.13}\protected@file@percent }
\newlabel{fig:block_adain}{{8}{6}{Content-style trade-off comparison of method variants on FID and Art-FID}{figure.caption.13}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Gamma Intensity Coefficient Sensitivity Analysis}{6}{subsection.4.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Results of $\gamma $ intensity coefficient sensitivity analysis (5-processor configuration in \texttt  {up\_blocks.0.attentions.1}, fixed AdaIN + ControlNet). $\gamma =0$ mainly retains content features with weak style injection; $\gamma =1$ yields the highest stylization degree but with more noticeable content change. Bold indicates our default configuration, not necessarily the single-metric optimum.}}{7}{table.caption.14}\protected@file@percent }
\newlabel{tab:gamma_ablation}{{7}{7}{Results of $\gamma $ intensity coefficient sensitivity analysis (5-processor configuration in \texttt {up\_blocks.0.attentions.1}, fixed AdaIN + ControlNet). $\gamma =0$ mainly retains content features with weak style injection; $\gamma =1$ yields the highest stylization degree but with more noticeable content change. Bold indicates our default configuration, not necessarily the single-metric optimum}{table.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Impact of $\gamma $ on FID, Art-FID, and LPIPS. As $\gamma $ increases, style fidelity generally improves but content change also increases; $\gamma =0.6$ is our adopted default trade-off point.}}{7}{figure.caption.15}\protected@file@percent }
\newlabel{fig:comprehensive}{{9}{7}{Impact of $\gamma $ on FID, Art-FID, and LPIPS. As $\gamma $ increases, style fidelity generally improves but content change also increases; $\gamma =0.6$ is our adopted default trade-off point}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Style transfer results at different $\gamma $ values under the AdaIN-enabled 5-processor configuration in \texttt  {up\_blocks.0.attentions.1} (our method). From left to right: $\gamma =0.2,0.4,0.8,1.0$. Style texture becomes stronger as $\gamma $ increases.}}{7}{figure.caption.16}\protected@file@percent }
\newlabel{fig:gamma_5blk}{{10}{7}{Style transfer results at different $\gamma $ values under the AdaIN-enabled 5-processor configuration in \texttt {up\_blocks.0.attentions.1} (our method). From left to right: $\gamma =0.2,0.4,0.8,1.0$. Style texture becomes stronger as $\gamma $ increases}{figure.caption.16}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Qualitative Analysis of StyleKV Target Processor Count}{7}{subsection.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Comparison of style transfer results under AdaIN-enabled 1-processor and 5-processor configurations in \texttt  {up\_blocks.0.attentions.1} at different $\gamma $ values. Top row: 1-proc StyleKV configuration; bottom row: 5-proc StyleKV configuration (our method). More target processors yield stronger style injection (more pronounced style texture in the bottom row) while still maintaining good content structure in the shown examples.}}{7}{figure.caption.17}\protected@file@percent }
\newlabel{fig:block_compare}{{11}{7}{Comparison of style transfer results under AdaIN-enabled 1-processor and 5-processor configurations in \texttt {up\_blocks.0.attentions.1} at different $\gamma $ values. Top row: 1-proc StyleKV configuration; bottom row: 5-proc StyleKV configuration (our method). More target processors yield stronger style injection (more pronounced style texture in the bottom row) while still maintaining good content structure in the shown examples}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Style transfer results under the AdaIN-enabled 10-processor configuration in \texttt  {up\_blocks.0.attentions.1} at different $\gamma $ values. Compared with the 5-proc configuration in the same block, 10-proc yields stronger style injection at the same $\gamma $, but content detail preservation is slightly inferior to the 5-proc configuration.}}{7}{figure.caption.18}\protected@file@percent }
\newlabel{fig:gamma_10blk}{{12}{7}{Style transfer results under the AdaIN-enabled 10-processor configuration in \texttt {up\_blocks.0.attentions.1} at different $\gamma $ values. Compared with the 5-proc configuration in the same block, 10-proc yields stronger style injection at the same $\gamma $, but content detail preservation is slightly inferior to the 5-proc configuration}{figure.caption.18}{}}
