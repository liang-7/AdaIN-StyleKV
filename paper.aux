\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces 不同块数配置与AdaIN使用与否的风格迁移效果对比。更多块数（5块 vs 1块）带来更强的风格注入，但也引入更多内容结构变化；AdaIN模块有助于在风格注入的同时保持色彩和谐。}}{6}{figure.caption.7}\protected@file@percent }
\newlabel{fig:block_adain}{{3}{6}{不同块数配置与AdaIN使用与否的风格迁移效果对比。更多块数（5块 vs 1块）带来更强的风格注入，但也引入更多内容结构变化；AdaIN模块有助于在风格注入的同时保持色彩和谐。}{figure.caption.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces $\gamma $消融实验结果（5块配置，固定AdaIN + ControlNet）。$\gamma =0$时完全保留内容特征（FID 76.57），风格最弱；$\gamma =1$时完全使用风格特征（FID 82.36），内容损失最大。$\gamma =0.6$为最佳权衡点——风格强度足够且内容结构保持良好（Art-FID 85.43）。}}{6}{table.caption.8}\protected@file@percent }
\newlabel{tab:gamma_ablation}{{5}{6}{$\gamma $消融实验结果（5块配置，固定AdaIN + ControlNet）。$\gamma =0$时完全保留内容特征（FID 76.57），风格最弱；$\gamma =1$时完全使用风格特征（FID 82.36），内容损失最大。$\gamma =0.6$为最佳权衡点——风格强度足够且内容结构保持良好（Art-FID 85.43）。}{table.caption.8}{}}
