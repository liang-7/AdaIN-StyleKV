\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces 块数消融实验结果（固定$\gamma =0.6$，使用AdaIN）。1块配置风格注入最保守（FID 73.34），5块配置获得最优Art-FID（90.76），2块配置结果居中。更多块带来更强风格注入，5块在效果与效率之间取得最佳平衡。}}{7}{table.caption.9}\protected@file@percent }
\newlabel{tab:block_ablation}{{6}{7}{块数消融实验结果（固定$\gamma =0.6$，使用AdaIN）。1块配置风格注入最保守（FID 73.34），5块配置获得最优Art-FID（90.76），2块配置结果居中。更多块带来更强风格注入，5块在效果与效率之间取得最佳平衡。}{table.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces 不同块数与AdaIN配置的定性对比。使用AdaIN的配置（前两行，标注为"是"）色彩协调性更优、风格覆盖更均匀；不使用AdaIN的配置（后两行，标注为"否"）风格迁移更强但内容结构退化更明显。}}{7}{table.caption.10}\protected@file@percent }
\newlabel{tab:qual_blocks}{{7}{7}{不同块数与AdaIN配置的定性对比。使用AdaIN的配置（前两行，标注为"是"）色彩协调性更优、风格覆盖更均匀；不使用AdaIN的配置（后两行，标注为"否"）风格迁移更强但内容结构退化更明显。}{table.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.7}实验中的关键问题}{7}{subsection.4.7}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.7.1}Canny边缘图分辨率与推理时间的权衡}{7}{subsubsection.4.7.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Canny分辨率与推理时间对比。高分辨率Canny边缘图可提供更丰富的结构信息从而提升生成效果，但推理时间非线性增长（从1080p约12秒到4K约68秒），且精细边缘图可能引入更多"幻觉"——模型生成边缘图中不存在的统计合理细节。}}{7}{table.caption.12}\protected@file@percent }
\newlabel{tab:resolution_canny}{{8}{7}{Canny分辨率与推理时间对比。高分辨率Canny边缘图可提供更丰富的结构信息从而提升生成效果，但推理时间非线性增长（从1080p约12秒到4K约68秒），且精细边缘图可能引入更多"幻觉"——模型生成边缘图中不存在的统计合理细节。}{table.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces 用户偏好研究结果：7名参与者对7种方法在7组内容-风格对上的排序评分（1为最佳，7为最差）。}}{7}{figure.caption.11}\protected@file@percent }
\newlabel{fig:user_study}{{4}{7}{用户偏好研究结果：7名参与者对7种方法在7组内容-风格对上的排序评分（1为最佳，7为最差）。}{figure.caption.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces 输入分辨率与推理时间对比。从标准分辨率（1080p，约13秒）到高分辨率（2106p，约63秒），推理时间增长非线性。合适的Canny分辨率需在图像质量与计算开销之间权衡：过低会丢失主体细节，过高则引入过多幻觉且耗时剧增。}}{7}{table.caption.13}\protected@file@percent }
\newlabel{tab:resolution_input}{{9}{7}{输入分辨率与推理时间对比。从标准分辨率（1080p，约13秒）到高分辨率（2106p，约63秒），推理时间增长非线性。合适的Canny分辨率需在图像质量与计算开销之间权衡：过低会丢失主体细节，过高则引入过多幻觉且耗时剧增。}{table.caption.13}{}}
