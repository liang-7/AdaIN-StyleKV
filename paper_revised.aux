\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}方法变体设计}{5}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces 7组方法变体在FID、Art-FID和LPIPS三项指标上的定量对比，三项指标均为越低越好。FID反映生成结果与内容域的分布距离，Art-FID反映与目标艺术风格域的接近程度，LPIPS反映感知层面的图像变化幅度。V6（Ours w/o AdaIN）取得最低Art-FID，风格注入更强；相较于V6，完整方法V7（Ours AdaIN, $\gamma =0.6$）降低LPIPS，感知变化更温和。}}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:variants2}{{6}{5}{7组方法变体在FID、Art-FID和LPIPS三项指标上的定量对比，三项指标均为越低越好。FID反映生成结果与内容域的分布距离，Art-FID反映与目标艺术风格域的接近程度，LPIPS反映感知层面的图像变化幅度。V6（Ours w/o AdaIN）取得最低Art-FID，风格注入更强；相较于V6，完整方法V7（Ours AdaIN, $\gamma =0.6$）降低LPIPS，感知变化更温和。}{figure.caption.4}{}}
