\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces AdaIN StyleKV整体方法流程框架图。给定内容图像与风格图像，首先使用VAE编码器将二者编码到潜空间，同时将内容图像的Canny边缘图作为ControlNet空间条件；在DDIM反演阶段获得内容图像与风格图像的潜变量轨迹；文本条件与图像条件经跨模态AdaIN进行特征融合；反向扩散过程中缓存风格图像在目标block \texttt  {up\_blocks.0.attentions.1} 内选定self-attention processor中的K/V特征，并与内容图像对应processor的K/V进行加权融合，最终经VAE解码器生成风格化图像。}}{3}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:pipeline}{{2}{3}{AdaIN StyleKV整体方法流程框架图。给定内容图像与风格图像，首先使用VAE编码器将二者编码到潜空间，同时将内容图像的Canny边缘图作为ControlNet空间条件；在DDIM反演阶段获得内容图像与风格图像的潜变量轨迹；文本条件与图像条件经跨模态AdaIN进行特征融合；反向扩散过程中缓存风格图像在目标block \texttt {up\_blocks.0.attentions.1} 内选定self-attention processor中的K/V特征，并与内容图像对应processor的K/V进行加权融合，最终经VAE解码器生成风格化图像。}{figure.caption.1}{}}
